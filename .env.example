# ──────────────────────────────────────────────
# WPI Credential System — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Alchemy RPC URL (Sepolia testnet)
# Sign up free at https://www.alchemy.com/
ALCHEMY_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deployer wallet private key (MetaMask)
# Export from MetaMask: Account Details > Show Private Key
# Fund with free Sepolia ETH from https://faucets.chain.link/
PRIVATE_KEY=your_private_key_here

# Etherscan API key (for contract verification)
# Sign up free at https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_api_key

# Chainlink Functions subscription ID (for ImpactVerifier)
# Create at https://functions.chain.link/
CHAINLINK_SUBSCRIPTION_ID=

# Pinata API keys (for IPFS uploads)
# Sign up free at https://www.pinata.cloud/
PINATA_API_KEY=
PINATA_SECRET_KEY=
